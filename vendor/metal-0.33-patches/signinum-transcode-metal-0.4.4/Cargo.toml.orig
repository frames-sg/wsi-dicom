[package]
name = "signinum-transcode-metal"
description = "Metal acceleration for signinum-transcode coefficient-domain paths"
version = "0.4.4"
edition.workspace = true
rust-version.workspace = true
license.workspace = true
repository.workspace = true
keywords.workspace = true
categories.workspace = true
readme = "README.md"

[package.metadata.docs.rs]
all-features = true
targets = []

[lib]
name = "signinum_transcode_metal"
path = "src/lib.rs"

[dependencies]
signinum-transcode = { path = "../signinum-transcode", version = "=0.4.4" }

[target.'cfg(target_os = "macos")'.dependencies]
metal = "0.31"
rayon = "1"

[dev-dependencies]
criterion = { workspace = true }
signinum-j2k-native = { path = "../signinum-j2k-native", version = "=0.4.4" }
signinum-jpeg = { path = "../signinum-jpeg", version = "=0.4.4" }

[[bench]]
name = "dct97"
harness = false

[lints.rust]
unsafe_code = "allow"
unsafe_op_in_unsafe_fn = "deny"
unreachable_pub = "warn"

[lints.clippy]
pedantic = { level = "warn", priority = -1 }
module_name_repetitions = "allow"
must_use_candidate = "allow"
missing_errors_doc = "allow"
missing_panics_doc = "allow"
cast_possible_truncation = "allow"
cast_precision_loss = "allow"
